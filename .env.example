################################################################################
# SecureVault — Environment Configuration
#
# Copy this file to `.env`, then run `php artisan key:generate` to populate
# APP_KEY. APP_KEY is THE encryption key for every credential, note, and
# custom field — back it up and never rotate it casually (rotation requires
# re-encrypting every row).
################################################################################

APP_NAME=SecureVault
APP_ENV=local                 # production | staging | local | testing
APP_KEY=                      # generated by `php artisan key:generate`
APP_DEBUG=true                # MUST be false in production
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# --- Logging -------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug               # production: warning or error

# --- Database (MySQL/MariaDB recommended) --------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=securevault
DB_USERNAME=root
DB_PASSWORD=

# --- Session security ----------------------------------------------------
# 15-minute idle session, encrypted, strict same-site cookies, secure-only
# behind HTTPS in production.
SESSION_DRIVER=database
SESSION_LIFETIME=15
SESSION_EXPIRE_ON_CLOSE=true
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false   # set to true behind HTTPS / production
SESSION_SAME_SITE=strict

# --- Other Laravel defaults ----------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (used only for password reset emails) --------------------------
MAIL_MAILER=log               # production: smtp | ses | postmark
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="vault@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS / S3 (not required) ---------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

################################################################################
# SecureVault-specific settings
################################################################################

# How many seconds of mouse/keyboard inactivity before the JS auto-logout
# fires. The server-side session also expires per SESSION_LIFETIME.
VAULT_IDLE_TIMEOUT_SECONDS=600

# How long a copied password stays on the clipboard before being wiped.
VAULT_CLIPBOARD_CLEAR_SECONDS=30

# How long the "Reveal password" button keeps the password visible before
# auto-hiding it.
VAULT_PASSWORD_REVEAL_SECONDS=10

# Default length used by the "Generate" button inside the credential form.
VAULT_DEFAULT_PASSWORD_LENGTH=20

# Maximum login attempts per minute per email+IP combination.
VAULT_LOGIN_RATE_LIMIT=5

# Force-HTTPS redirect (off in local/testing regardless of value).
VAULT_FORCE_HTTPS=false

# Optional IP allow-list. Disabled by default; when enabled, only the
# listed comma-separated IPs may reach the vault.
VAULT_IP_WHITELIST_ENABLED=false
VAULT_IP_WHITELIST=
